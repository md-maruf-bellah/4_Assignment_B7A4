{
  "info": {
    "name": "RentNest API",
    "description": "Rental Property Marketplace Backend API - covers Auth, Properties, Landlord, Rentals, Payments, Reviews, and Admin endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5000/api" },
    { "key": "tenantToken", "value": "" },
    { "key": "landlordToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "propertyId", "value": "" },
    { "key": "categoryId", "value": "" },
    { "key": "rentalRequestId", "value": "" },
    { "key": "paymentId", "value": "" },
    { "key": "userId", "value": "" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register Tenant",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Ayesha Siddiqua\",\n  \"email\": \"tenant@rentnest.com\",\n  \"password\": \"tenant123\",\n  \"phone\": \"+8801800000000\",\n  \"role\": \"TENANT\"\n}"
            }
          }
        },
        {
          "name": "Register Landlord",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Karim Rahman\",\n  \"email\": \"landlord@rentnest.com\",\n  \"password\": \"landlord123\",\n  \"phone\": \"+8801700000000\",\n  \"role\": \"LANDLORD\"\n}"
            }
          }
        },
        {
          "name": "Login Tenant",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data && data.data && data.data.token) { pm.collectionVariables.set('tenantToken', data.data.token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"tenant@rentnest.com\",\n  \"password\": \"tenant123\"\n}"
            }
          }
        },
        {
          "name": "Login Landlord",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data && data.data && data.data.token) { pm.collectionVariables.set('landlordToken', data.data.token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"landlord@rentnest.com\",\n  \"password\": \"landlord123\"\n}"
            }
          }
        },
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data && data.data && data.data.token) { pm.collectionVariables.set('adminToken', data.data.token); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "url": "{{baseUrl}}/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"admin@rentnest.com\",\n  \"password\": \"admin123\"\n}"
            }
          }
        },
        {
          "name": "Get Current User (Me)",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tenantToken}}" }],
            "url": "{{baseUrl}}/auth/me"
          }
        }
      ]
    },
    {
      "name": "Properties (Public)",
      "item": [
        {
          "name": "Get All Properties (with filters)",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/properties?city=Rajshahi&minPrice=5000&maxPrice=50000&page=1&limit=10"
          }
        },
        {
          "name": "Get Property By Id",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/properties/{{propertyId}}"
          }
        },
        {
          "name": "Get All Categories",
          "request": {
            "method": "GET",
            "url": "{{baseUrl}}/categories"
          }
        }
      ]
    },
    {
      "name": "Landlord",
      "item": [
        {
          "name": "Create Property",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data && data.data && data.data.id) { pm.collectionVariables.set('propertyId', data.data.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{landlordToken}}" }
            ],
            "url": "{{baseUrl}}/landlord/properties",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Cozy 2-Bed Apartment\",\n  \"description\": \"A well-lit modern apartment close to the university.\",\n  \"type\": \"APARTMENT\",\n  \"price\": 15000,\n  \"location\": \"Shaheb Bazar\",\n  \"city\": \"Rajshahi\",\n  \"address\": \"House 12, Road 4, Shaheb Bazar\",\n  \"bedrooms\": 2,\n  \"bathrooms\": 2,\n  \"areaSqft\": 950,\n  \"amenities\": [\"WiFi\", \"Parking\"],\n  \"images\": [],\n  \"categoryId\": \"{{categoryId}}\"\n}"
            }
          }
        },
        {
          "name": "Get My Properties",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{landlordToken}}" }],
            "url": "{{baseUrl}}/landlord/properties"
          }
        },
        {
          "name": "Update Property",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{landlordToken}}" }
            ],
            "url": "{{baseUrl}}/landlord/properties/{{propertyId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"price\": 16000,\n  \"status\": \"AVAILABLE\"\n}"
            }
          }
        },
        {
          "name": "Delete Property",
          "request": {
            "method": "DELETE",
            "header": [{ "key": "Authorization", "value": "Bearer {{landlordToken}}" }],
            "url": "{{baseUrl}}/landlord/properties/{{propertyId}}"
          }
        },
        {
          "name": "Get Rental Requests For My Properties",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{landlordToken}}" }],
            "url": "{{baseUrl}}/landlord/requests"
          }
        },
        {
          "name": "Approve/Reject Rental Request",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{landlordToken}}" }
            ],
            "url": "{{baseUrl}}/landlord/requests/{{rentalRequestId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"APPROVED\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Rental Requests",
      "item": [
        {
          "name": "Submit Rental Request",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data && data.data && data.data.id) { pm.collectionVariables.set('rentalRequestId', data.data.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tenantToken}}" }
            ],
            "url": "{{baseUrl}}/rentals",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"propertyId\": \"{{propertyId}}\",\n  \"moveInDate\": \"2026-08-01\",\n  \"message\": \"I would like to move in as soon as possible.\"\n}"
            }
          }
        },
        {
          "name": "Get My Rental Requests",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tenantToken}}" }],
            "url": "{{baseUrl}}/rentals"
          }
        },
        {
          "name": "Get Rental Request By Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tenantToken}}" }],
            "url": "{{baseUrl}}/rentals/{{rentalRequestId}}"
          }
        }
      ]
    },
    {
      "name": "Payments",
      "item": [
        {
          "name": "Create Payment Session",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tenantToken}}" }
            ],
            "url": "{{baseUrl}}/payments/create",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rentalRequestId\": \"{{rentalRequestId}}\"\n}"
            }
          }
        },
        {
          "name": "Confirm Payment",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tenantToken}}" }
            ],
            "url": "{{baseUrl}}/payments/confirm",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionId\": \"cs_test_xxx\"\n}"
            }
          }
        },
        {
          "name": "Get My Payment History",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tenantToken}}" }],
            "url": "{{baseUrl}}/payments"
          }
        },
        {
          "name": "Get Payment By Id",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tenantToken}}" }],
            "url": "{{baseUrl}}/payments/{{paymentId}}"
          }
        }
      ]
    },
    {
      "name": "Reviews",
      "item": [
        {
          "name": "Create Review",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tenantToken}}" }
            ],
            "url": "{{baseUrl}}/reviews",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"rentalRequestId\": \"{{rentalRequestId}}\",\n  \"rating\": 5,\n  \"comment\": \"Great place, responsive landlord!\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Admin",
      "item": [
        {
          "name": "Get All Users",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/users"
          }
        },
        {
          "name": "Update User Status (Ban/Unban)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/admin/users/{{userId}}",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"BANNED\"\n}"
            }
          }
        },
        {
          "name": "Get All Properties",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/properties"
          }
        },
        {
          "name": "Get All Rental Requests",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
            "url": "{{baseUrl}}/admin/rentals"
          }
        },
        {
          "name": "Create Category",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const data = pm.response.json();",
                  "if (data && data.data && data.data.id) { pm.collectionVariables.set('categoryId', data.data.id); }"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{adminToken}}" }
            ],
            "url": "{{baseUrl}}/admin/categories",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Apartment\"\n}"
            }
          }
        }
      ]
    }
  ]
}
